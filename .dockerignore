# Runtime data and databases (contains sensitive content and temp files)
data/
.env

# Build artifacts
bin/
*.exe
*.dll
*.so
*.dylib

# Test artifacts
*.test
*.out
coverage.out
coverage.html

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git files
.git/
.gitignore

# Documentation (exclude user docs but keep swagger API docs needed for build)
docs/*.md
!docs/swagger/
!README.md

# CI/CD files
.github/
docker-compose.yml
docker-compose.yaml

# Node modules (frontend dependencies, will be installed in container)
web/frontend/node_modules/

# Go module cache (go.sum must be included for reproducible builds)
# go.sum should NOT be excluded - it's needed for dependency verification

# Logs
*.log

# Temporary files
tmp/
temp/
*.tmp
